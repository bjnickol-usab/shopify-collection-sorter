# Shopify App Credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Your Vercel app URL (update after first deployment)
SHOPIFY_APP_URL=https://shopify-collection-sorter.vercel.app

# Supabase (from Supabase project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Encryption key for session storage (generate with: openssl rand -base64 32)
SESSION_SECRET=your_random_session_secret
